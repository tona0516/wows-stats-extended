doctype html
head
  title
  link(crossorigin='anonymous' href='https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css' integrity='sha384-MCw98/SFnGE8fJT3GXwEOngsV7Zt27NXFoaoApmYm81iuXoPkFOJwJ8ERdknLPMO' rel='stylesheet')
  link(rel='stylesheet' href='../stylesheets/style.css')
body(class='custom-dark')
#app
  div(v-if='message != null')
    .alert.alert-primary {{ message }}
  div(v-if='error != null')
    .alert.alert-danger {{ error }}
  div(v-for='team of teams')
    table.table.table-sm.table-dark.table-bordered.table-hover
      thead
        th(colspan='2' style='width: 25%') &#x30D7;&#x30EC;&#x30A4;&#x30E4;&#x30FC;&#x60C5;&#x5831;
        th(colspan='4' style='width: 25%') &#x8266;&#x8247;&#x60C5;&#x5831;
        th(colspan='4' style='width: 25%') &#x8266;&#x8247;&#x7D71;&#x8A08;
        th(colspan='6' style='width: 25%') &#x30D7;&#x30EC;&#x30A4;&#x30E4;&#x30FC;&#x7D71;&#x8A08;
      tr
        td(style='width: 15%') &#x30D7;&#x30EC;&#x30A4;&#x30E4;&#x30FC;&#x540D;
        td(style='width: 10%') &#x6226;&#x95D8;&#x529B;
        td(style='width: 13%') &#x8266;&#x540D;
        td(style='width: 4%') Tier
        td(style='width: 4%') &#x96A0;&#x853D;
        td(style='width: 4%') &#x30EC;&#x30FC;&#x30C0;&#x30FC;
        td &#x4E0E;&#x30C0;&#x30E1;
        td &#x52DD;&#x7387;
        td K/D
        td &#x6226;&#x95D8;&#x6570;
        td &#x4E0E;&#x30C0;&#x30E1;
        td &#x52DD;&#x7387;
        td K/D
        td &#x6226;&#x95D8;&#x6570;
        td &#x5E73;&#x5747;Tier
      tr(v-for='player of team')
        // プレイヤー情報
        td
          font(v-if='player.playerInfo.clan != null' color='#B6FF01') [{{ player.playerInfo.clan }}]
          font(color='#FFFFFF')
            span {{ player.playerInfo.name }}
        td {{ player.shipStats.combatPower }}
        // 艦艇情報
        td {{ player.shipInfo.name }}
        td {{ player.shipInfo.tier }}
        td {{ player.shipInfo.detectDistance }}
        td {{ player.shipInfo.radarDistance }}
        // 艦艇統計
        td {{ player.shipStats.averageDamage }}
        td {{ player.shipStats.winRate }}
        td {{ player.shipStats.killDeathRate }}
        td {{ player.shipStats.battles }}
        // プレイヤー統計
        td {{ player.playerStats.averageDamage }}
        td {{ player.playerStats.winRate }}
        td {{ player.playerStats.killDeathRate }}
        td {{ player.playerStats.battles }}
        td {{ player.playerStats.averageTier }}
script(src='https://cdn.jsdelivr.net/npm/vue/dist/vue.js')
script(src='https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js')
script(crossorigin='anonymous' integrity='sha384-ChfqqxuZUCnJSK3+MXmPNIyE6ZbWh2IMqE241rYiqJxyMiZ6OW/JmZQ5stwEULTy' src='https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/js/bootstrap.min.js')
script(src='../javascripts/index.js')
